<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Tell IISNode which file is the entry point -->
    <iisnode
      nodeProcessCommandLine="node.exe --experimental-vm-modules"
      loggingEnabled="true"
      logDirectory="iisnode"
      watchedFiles="*.js;*.json"
      node_env="production"
    />

    <handlers>
      <!-- Route all requests through the Node.js entry point -->
      <add name="iisnode" path="index.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Do NOT rewrite requests for iisnode log files -->
        <rule name="LogFiles" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="iisnode" />
        </rule>

        <!-- Do NOT rewrite requests for static node_modules -->
        <rule name="NodeModules" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="node_modules[/\\].+" />
        </rule>

        <!-- Route everything else to the Node app -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Allow IIS to serve static files from the client/dist folder directly -->
    <staticContent>
      <mimeMap fileExtension=".jsx"  mimeType="text/javascript" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
